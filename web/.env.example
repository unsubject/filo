# Copy to `.env.local` and fill in. Both are optional in dev.

# Base URL of the filo Worker API. Defaults to http://localhost:8787.
VITE_API_BASE=http://localhost:8787

# LOCAL-DEV ONLY. Setting this INLINES the bearer token into the built JS bundle
# — anyone who can load the app could recover it and call every API route. Never
# use it for a production (Cloudflare Pages) build.
#
# In `npm run dev` this value only SEEDS localStorage["filo_token"] once (the
# read is dead-code-eliminated from production builds). In production the token
# is entered at RUNTIME via the app's token gate and lives only in localStorage
# on your device — it is never part of the bundle. Leave this blank for prod.
VITE_FILO_TOKEN=

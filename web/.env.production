# Production build config — committed on purpose; contains NO secrets.
# Vite loads this during `vite build` (production mode), so the deployed SPA
# points at the Worker API without needing a Pages dashboard env var.
#
# The bearer token is deliberately NOT set here — it is entered at runtime and
# stored in localStorage via the app's token gate (see web/src/api/client.ts).
VITE_API_BASE=https://filo.simon-lee.workers.dev
